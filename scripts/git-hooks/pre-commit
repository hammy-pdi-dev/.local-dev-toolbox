#!/bin/bash

# NOTES:
# This script runs gitleaks against staged changes to prevent secrets from being committed.
# Copy this file into your repository's `.git/hooks/` folder.
# Requires gitleaks to be installed: https://github.com/gitleaks/gitleaks#installing

# Allow bypassing the hook with SKIP_GITLEAKS=1 for cases where a false positive is blocking.
if [[ "${SKIP_GITLEAKS:-0}" == "1" ]]; then
    echo "Info: Skipping gitleaks check (SKIP_GITLEAKS=1)."
    exit 0
fi

if ! command -v gitleaks &>/dev/null; then
    echo "Warning: gitleaks is not installed. Skipping secret scan."
    echo "Install: https://github.com/gitleaks/gitleaks#installing"
    exit 0
fi

# Run gitleaks against staged changes only
gitleaks git --pre-commit --staged --verbose

exit_code=$?

if [[ $exit_code -ne 0 ]]; then
    echo ""
    echo "Error: gitleaks detected potential secrets in staged changes."
    echo "Review the output above and either:"
    echo "  1. Remove the secret from your changes"
    echo "  2. Add a gitleaks:allow comment inline if it's a false positive"
    echo "  3. Add the pattern to .gitleaks.toml [allowlist] if it's a known false positive"
    echo "  4. Set SKIP_GITLEAKS=1 to bypass this check (use sparingly)"
    exit 1
fi
